# 电商客服机器人 SaaS 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============ JWT 密钥（生产环境务必修改）============
SECRET_KEY=your-super-secret-key-change-in-production

# ============ 豆包 AI 配置 ============
# ARK API Key
ARK_API_KEY=ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 豆包 API 端点
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3

# 模型 ID
DOUBAO_MODEL_ID=ep-xxxxxxxxxxxxxxxxxxxxxxxx

# ============ 拼多多 API 配置（可选）============
PINDUODUO_CLIENT_ID=your-pinduoduo-client-id
PINDUODUO_CLIENT_SECRET=your-pinduoduo-client-secret
